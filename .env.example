# NVIDIA NIM API Key for LLM services
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# SMTP Configuration (For Candidate email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password_or_app_password

# Calendar Configuration
# Set to 'True' to mock Google Calendar events and link generation without credentials
MOCK_CALENDAR=True
GOOGLE_CALENDAR_CREDENTIALS=
